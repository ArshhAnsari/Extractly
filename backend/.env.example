# Django
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# SimpleJWT
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_WEBHOOK_SECRET=   # same as CLOUDINARY_API_SECRET

# Google Vision
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/vision-key.json

# Image OCR
IMAGE_OCR_PROVIDER=ocr_space
OCR_SPACE_API_KEY=

# LLM
LLM_PROVIDER=openai          # or gemini
OPENAI_API_KEY=
GEMINI_API_KEY=

# Upload / Processing constraints (all have sensible defaults; set to override)
MAX_FILE_SIZE_BYTES=5242880     # 5 MB  (matches MAX_UPLOAD_FILE_SIZE_MB=5)
FILE_DOWNLOAD_TIMEOUT_SECONDS=30
MAX_FILES_PER_JOB=100
BATCH_SIZE=10                   # files per Celery task

# LLM retry / backoff (tenacity)
LLM_RETRY_MAX_ATTEMPTS=4
LLM_RETRY_MIN_SECONDS=1
LLM_RETRY_MAX_SECONDS=20